# Notion
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database IDs — add one per entry in databases.json (names must match "env_var" values)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_2_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_3_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Azure AD app registration (for Microsoft Graph API)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-here

# Email
SENDER_EMAIL=sender@yourdomain.com
RECIPIENT_EMAIL=recipient@yourdomain.com
