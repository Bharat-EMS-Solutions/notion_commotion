# Notion
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database IDs — add one per entry in databases.json (names must match "env_var" values)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_2_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_DATABASE_3_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Azure AD app registration (for Microsoft Graph API)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-here

# Daily digest / Actionable Messages
# Public base URL of this Flask server (used in email card action URLs)
APP_BASE_URL=https://your-server.example.com
# Originator GUID from the Actionable Email Developer Dashboard (set after registration)
ACTIONABLE_MSG_ORIGINATOR=
# Set to "true" to skip JWT validation during local development
LOG_HOURS_DEV=true
